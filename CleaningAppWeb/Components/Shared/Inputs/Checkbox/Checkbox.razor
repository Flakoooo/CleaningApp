<div class="d-flex" style="cursor: pointer;" @onclick="() => SelectCheckbox()">
    <input type="@InputType.Checkbox.ToString().ToLower()"
           checked="@Checked"
           class="form-check-input"
           style="cursor: pointer;"
           @onclick="() => SelectCheckbox()"
           @onclick:stopPropagation="true" />
    @if (!string.IsNullOrWhiteSpace(DisplayText))
    {
        <span class="form-check-label ms-2 @DisplayTextCustomClass">
            @DisplayText
        </span>
    }
</div>

@code {
    [Parameter]
    public bool Checked { get; set; } = false;

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public string DisplayText { get; set; } = string.Empty;

    [Parameter]
    public string DisplayTextCustomClass { get; set; } = string.Empty;

    private async Task SelectCheckbox()
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }
}
