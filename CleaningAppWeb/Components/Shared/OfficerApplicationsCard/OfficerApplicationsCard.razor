@using CleaningAppWeb.Components.Services
@using CleaningAppWeb.Components.Shared.ApplicationCard
@using CleaningAppWeb.Components.Shared.ApplicationModal
@inherits PaginationLoader

<div class="applications-card">
    <div class="applications-card-header">@Label</div>
    <div class="applications-card-list" @ref="_tableContainer">
        @foreach (var application in _applications)
        {
            <ApplicationCard CleaningApplication="application" 
                             OnCardClick="() => SelectApplication(application.Id)" />
        }
    </div>
</div>

@if (_applicationModalActive)
{
    <ApplicationModal ApplicationId="_selectedApplicationId"
                      OnModalClose="ModalClose"/>
}