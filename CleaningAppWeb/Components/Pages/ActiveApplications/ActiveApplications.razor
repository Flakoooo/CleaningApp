@page "/active-applications"
@attribute [Authorize(Roles = "Cleaner")]
@using CleaningAppWeb.Components.Models
@using CleaningAppWeb.Components.Services
@using CleaningAppWeb.Components.Shared.ApplicationCard
@using CleaningAppWeb.Components.Shared.Button
@using CleaningAppWeb.Components.Shared.CheckboxFilter
@using CleaningAppWeb.Components.Shared.Inputs.Number
@using CleaningAppWeb.Domain.DTOs
@using CleaningAppWeb.Domain.Enums
@using Microsoft.AspNetCore.Authorization
@rendermode InteractiveServer
@inherits PaginationLoader

<div class="active-applications-page">
    <div class="acitve-applications-card">
        <div class="active-applications-list" @ref="_tableContainer">
            @foreach (var application in _applications)
            {
                <ApplicationCard CleaningApplication="application" />
            }
        </div>
        <div class="active-applications-filter">
            <CheckboxFilter T="ValueSelectableItem<CleaningApplicationStatus>" 
                            Label="Статус заявки"
                            AllValues="_filterStatuses"
                            FilterChanged="() => LoadApplicationsAsync()"
                            @bind-SelectedValues="_selectedStatuses" />
            <CheckboxFilter T="ServiceDTO"
                            AllValues="_filterServices"
                            Label="Тип услуги"
                            FilterChanged="() => LoadApplicationsAsync()"
                            @bind-SelectedValues="_selectedServices" />
            @*debounce нужен*@
            <Number T="int" 
                    Label="Количество кабинетов" 
                    MinValue="0"
                    Value="_roomsCount"
                    ValueChanged="async (value) => await SetRoomsCount(value)"  
                    Placeholder="Введите количество кабинетов" />
            <CheckboxFilter T="OfficeDTO"
                            DataLoaderMethod="async (page) => await OfficesService.GetOfficesAsync(page)"
                            @bind-SelectedValues="_selectedOffices"
                            FilterChanged="() => LoadApplicationsAsync()"
                            Label="Адрес" />
            <CheckboxFilter T="ValueSelectableItem<TimeOnly>" 
                            AllValues="_filterTime" 
                            Label="Время"
                            FilterChanged="() => LoadApplicationsAsync()"
                            @bind-SelectedValues="_selectedTimes" />
            <Button Width="width: 100%;" 
                    Text="Сбросить фильтры"
                    OnButtonClick="ResetFilters" />
        </div>
    </div>
</div>