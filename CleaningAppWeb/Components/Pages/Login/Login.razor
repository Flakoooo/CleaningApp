@page "/login"
@using CleaningAppWeb.Components.Shared.Button
@using CleaningAppWeb.Components.Shared.Inputs.Input
<div class="login-page">
    <div class="login-card">
        <div class="fs-2" style="color: #312B2B">Авторизация</div>
        <div class="d-flex flex-column gap-2" style="width: 95%;">
            <Input IconStyle="bi-at" Placeholder="Введите логин" />
            <Input IconStyle="bi-key-fill" Placeholder="Введите пароль" />
        </div>
        <Button Width="width: 85%;" Text="Вход" />
    </div>
</div>