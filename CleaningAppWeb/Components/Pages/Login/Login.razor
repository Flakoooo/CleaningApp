@using CleaningAppWeb.Components.Shared.Button
@using CleaningAppWeb.Components.Shared.Inputs
@using CleaningAppWeb.Components.Shared.Inputs.Input
@rendermode InteractiveServer

<PageTitle>Вход</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="fs-2" style="color: var(--ca-black)">Авторизация</div>
        <div class="d-flex flex-column gap-3" style="width: 92%;">
            <Input IconStyle="bi-at" 
                   Placeholder="Введите логин"
                   ErrorMessage="@_errors.GetValueOrDefault("login")"
                   @bind-Value="_login" />
            <Input InputType="InputType.Password" 
                   IconStyle="bi-key-fill" 
                   Placeholder="Введите пароль"
                   ErrorMessage="@_errors.GetValueOrDefault("password")"
                   @bind-Value="_password"/>
        </div>
        <Button Width="width: 85%;" 
                IsMainButton="true"
                Text="Вход"
                ButtonClass="mb-1 mt-3"
                OnButtonClick="LoginUser" />
    </div>
</div>